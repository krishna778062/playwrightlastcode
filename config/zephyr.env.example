# Zephyr Squad API Configuration
# Copy this file to zephyr.env for local development
# For CI/CD, set these as environment variables in your CI platform

# API Access Credentials
ZEPHYR_ACCESS_KEY=your_access_key_here
ZEPHYR_SECRET_KEY=your_secret_key_here
ZEPHYR_ACCOUNT_ID=your_account_id_here

# API Endpoint
ZEPHYR_BASE_URL=https://prod-api.zephyr4jiracloud.com/connect 