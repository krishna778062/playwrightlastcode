{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@core/*": ["./src/core/*"],
      "@core/ui/*": ["./src/core/ui/*"],
      "@core/components/*": ["./src/core/ui/components/*"],
      "@core/pages/*": ["./src/core/ui/pages/*"],
      "@core/ui/components/*": ["./src/core/ui/components/*"],
      "@common-utils/*": ["src/core/utils/*"],
      "@api/*": ["./src/core/api/*"],
      "@types/*": ["./src/core/types/*"],
      "@modules/*": ["./src/modules/*"],
      "@chat/*": ["./src/modules/chat/*"],
      "@data-engineering/*": ["./src/modules/data-engineering/*"],
      "@chat-helpers/*": ["./src/modules/chat/helpers/*"],
      "@chat-pages/*": ["./src/modules/chat/pages/*"],
      "@chat-components/*": ["./src/modules/chat/pages/components/*"],
      "@chat-tests/*": ["./src/modules/chat/tests/*"],
      "@platforms/*": ["./src/modules/platforms/*"],
      "@platforms-components/*": ["./src/modules/platforms/ui/components/*"],
      "@platforms-pages/*": ["./src/modules/platforms/ui/pages/*"],
      "@platforms-tests/*": ["./src/modules/platforms/tests/*"],
      "@content/*": ["./src/modules/content/*"],
      "@content-pages/*": ["./src/modules/content/pages/*"],
      "@content-components/*": ["./src/modules/content/ui/components/*"],
      "@content-tests/*": ["./src/modules/content/tests/*"],
      "@content-abac/*": ["./src/modules/content-abac/*"],
      "@content-abac/pages/*": ["./src/modules/content-abac/ui/pages/*"],
      "@content-abac/tests/*": ["./src/modules/content-abac/tests/*"],
      "@content-abac/components/*": ["./src/modules/content-abac/ui/components/*"],
      "@rewards/*": ["./src/modules/reward/*"],
      "@rewards-components/*": ["./src/modules/reward/ui/components/*"],
      "@rewards-pages/*": ["./src/modules/reward/ui/pages/*"],
      "@frontline/*": ["./src/modules/frontline/*"],
      "@frontline-components/*": ["./src/modules/frontline/ui/components/*"],
      "@frontline-pages/*": ["./src/modules/frontline/ui/pages/*"],
      "@integrations/*": ["./src/modules/integrations/*"],
      "@integrations-pages/*": ["src/modules/integrations/ui/pages/*"],
      "@integrations-components/*": ["./src/modules/integrations/ui/components/*"],
      "@integrations-constants/*": ["./src/modules/integrations/constants/*"],
      "@integrations-fixtures/*": ["./src/modules/integrations/fixtures/*"],
      "@integrations-api/*": ["src/modules/integrations/apis/*"],
      "@integrations-test-data/*": ["./src/modules/integrations/test-data/*"],
      "@integrations-helpers/*": ["./src/modules/integrations/apis/helpers/*"],
      "@alert-notification/*": ["./src/modules/alert-notification/*"],
      "@alert-notification-fixtures/*": ["src/modules/alert-notification/tests/fixtures/*"],
      "@alert-notification-pages/*": ["src/modules/alert-notification/ui/pages/*"],
      "@alert-notification-components/*": ["src/modules/alert-notification/ui/components/*"],
      "@alert-notification-tests/*": ["./src/modules/alert-notification/tests/*"],
      "@alert-notification-env/*": ["./src/modules/alert-notification/env/*"],
      "@alert-notification-constants/*": ["./src/modules/alert-notification/constants/*"],
      "@alert-notification-test-data/*": ["src/modules/alert-notification/tests/test-data/*"],
      "@employee-listening/*": ["./src/modules/employee-listening/*"]
    },
    "target": "ES2019",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}
