# Outlook Calendar Integration - App Manager
# Copy this file to outlookCalendarSecrets.env and fill in your actual values

OUTLOOK_CLIENT_ID=your_outlook_client_id_here
OUTLOOK_CLIENT_SECRET=your_outlook_client_secret_here
OUTLOOK_REFRESH_TOKEN=your_outlook_refresh_token_here

# Note: Access tokens are managed automatically by the token manager
# The system will use the refresh token above to automatically obtain and refresh access tokens as needed

# End User Outlook Calendar Credentials (for future use)
# END_USER_OUTLOOK_CLIENT_ID=your_end_user_client_id_here
# END_USER_OUTLOOK_CLIENT_SECRET=your_end_user_client_secret_here
# END_USER_OUTLOOK_REFRESH_TOKEN=your_end_user_refresh_token_here
